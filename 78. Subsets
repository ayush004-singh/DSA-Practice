class Solution {
    private static void sub(int[] arr, int n, int i, List<Integer> li, List<List<Integer>> ans){
        if(i==n){
            ans.add(new ArrayList<>(li));
            return;
        }

    // Include
    li.add(arr[i]);
    sub(arr,n,i+1,li,ans);
    li.remove(li.size()-1);

    //exlude
    sub(arr,n,i+1,li,ans);

    }
    public List<List<Integer>> subsets(int[] nums) {
        List<List<Integer>> ans = new ArrayList<>();
        sub(nums,nums.length,0,new ArrayList<>(),ans);
        return ans;


    }
}
