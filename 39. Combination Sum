class Solution {

    public static void comb(int nums[],
                            int i,
                            int n,
                            int target,
                            List<Integer> li,
                            List<List<Integer>> ans){

        // target achieved
        if(target == 0){
            ans.add(new ArrayList<>(li));
            return;
        }

       
        if(i == n || target < 0){
            return;
        }

        // TAKE current element
        li.add(nums[i]);

        
        comb(nums, i, n, target - nums[i], li, ans);

        
        li.remove(li.size()-1);

       
        comb(nums, i+1, n, target, li, ans);
    }

    public List<List<Integer>> combinationSum(int[] candidates,
                                              int target) {

        List<List<Integer>> ans = new ArrayList<>();

        comb(candidates,
             0,
             candidates.length,
             target,
             new ArrayList<>(),
             ans);

        return ans;
    }
}
