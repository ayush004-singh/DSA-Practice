class Solution {
    public boolean checkInclusion(String s1, String s2) {
         HashMap<Character,Integer> ch = new HashMap<>();
         for(char c:s1.toCharArray()){
            ch.put(c,ch.getOrDefault(c,0)+1);
         }
        int low=0;
        boolean flag=false;
        HashMap<Character,Integer> m = new HashMap<>();
        for(int high=0;high<s2.length();high++){
            char c=s2.charAt(high);
            m.put(c, m.getOrDefault(c,0)+1);
            int len=high-low+1;
            if(len>s1.length()){
                char sc=s2.charAt(low);
                m.put(sc, m.get(sc)-1);

                if(m.get(sc)==0){
                    m.remove(sc);
            }
                low++;
            }
           if(m.equals(ch)){
                flag= true;
            }
        }
        return flag;
    }
}
